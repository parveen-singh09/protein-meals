---
import { translations } from "../i18n";
import { foods } from "../data/foods";

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  showExactCount?: boolean;
}

const siteUrl = 'https://highproteinfoodz.com';
const { title = 'Highest Protein Foods Per 100g - 120+ High Protein Foods List & Complete Nutrition Data', description = 'Discover 120+ high protein foods with complete macros, prices, and nutrition data per 100g. The ultimate list of best high protein foods for weight loss, muscle building, and a healthy high protein diet.', ogImage = '/og-image.png', showExactCount = false } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <script is:inline>
      (function() {
        try {
          var theme = localStorage.getItem('theme');
          if (theme === 'dark') {
            document.documentElement.classList.add('dark');
          }
        } catch (e) {}
        document.documentElement.classList.add('theme-ready');
      })();
    </script>
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="ProteinLab" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="keywords" content="high protein foods, high protein diet, high protein foods list, highest protein foods per 100g, protein foods, protein rich foods, protein foods list, healthy high protein meals, high protein snacks, low calorie meals, protein in an egg, high protein, low calorie high protein foods, high protein foods for weight loss, best high protein foods" />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="HighProtein Foodz" />
    <link rel="canonical" href={siteUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="HighProtein Foodz" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link href="https://unpkg.com/lucide-static@latest/font/lucide.css" rel="stylesheet" />
    <link rel="preload" href="/background.jpg" as="image" />
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-HK1B2TBRNW"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-HK1B2TBRNW');
    </script>
  </head>
  <body>
    <slot />

    <script define:vars={{ translations, totalFoodsCount: foods.length, showExactCount }} is:inline>
      window.__translations = translations;
      window.__totalFoodsCount = showExactCount ? totalFoodsCount : "100+";
    </script>

    <script src="../i18n/i18n-client.js"></script>
  </body>
</html>

<style is:global>
  :root {
    --blur-amount: 15px;
    --glass-opacity: 0.15;
    --border-color: rgba(255, 255, 255, 0.2);
    --accent-green: #16a34a;
    --accent-green-light: #22c55e;
    --accent-lime: #84cc16;
    --accent-emerald: #059669;
    --accent-teal: #14b8a6;
    --bg-gradient-1: #e8f5e9;
    --bg-gradient-2: #f0fdf4;
    --bg-gradient-3: #dcfce7;
    --surface: rgba(255, 255, 255, 0.45);
    --surface-hover: rgba(255, 255, 255, 0.6);
    --text-primary: #1a2332;
    --text-secondary: #475569;
    --text-muted: #64748b;
    --card-bg: rgba(255, 255, 255, 0.3);
    --card-border: rgba(255, 255, 255, 0.4);
    --shadow: 0 8px 32px rgba(0, 0, 0, 0.06);
    --radius: 0.75rem;
    --max-width: 1280px;
    --font-sans: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    --font-mono: 'JetBrains Mono', monospace;
    --theme-transition: 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    --bg-solid: #eef7ef;
  }

  :root.dark {
    --bg-gradient-1: rgba(5,11,24,0.88);
    --bg-gradient-2: rgba(10,25,47,0.85);
    --bg-gradient-3: rgba(17,34,64,0.88);
    --surface: rgba(255, 255, 255, 0.07);
    --surface-hover: rgba(255, 255, 255, 0.12);
    --card-bg: rgba(255, 255, 255, 0.05);
    --card-border: rgba(255, 255, 255, 0.1);
    --text-primary: #f8fafc;
    --text-secondary: #cbd5e1;
    --text-muted: #94a3b8;
    --shadow: 0 8px 32px rgba(0, 0, 0, 0.5);
    --bg-solid: #0a1929;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  html.theme-ready {
    transition: color 0.35s ease;
  }

  body {
    margin: 0;
    padding: 0;
    width: 100%;
    min-height: 100dvh;
    font-family: var(--font-sans);
    background-color: var(--bg-solid);
    color: var(--text-primary);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body::before {
    content: "";
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    height: 100lvh;
    z-index: -1;
    background:
      linear-gradient(135deg, rgba(232,245,233,0.75), rgba(232,245,233,0.75), rgba(232,245,233,0.75)),
      url('/background.jpg') center / cover no-repeat;
    pointer-events: none;
    -webkit-transform: translate3d(0, 0, 0);
    transform: translate3d(0, 0, 0);
    will-change: transform;
  }

  :root.dark body::before {
    background:
      linear-gradient(135deg, var(--bg-gradient-1), var(--bg-gradient-1), var(--bg-gradient-1)),
      url('/background.jpg') center / cover no-repeat;
  }

  html.theme-ready .glass {
    transition: background 0.35s ease, border-color 0.35s ease, box-shadow 0.35s ease;
  }

  .gradient-text {
    background: linear-gradient(135deg, var(--accent-green), var(--accent-teal), var(--accent-lime));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  ::selection {
    background: rgba(22, 163, 74, 0.3);
    color: white;
  }

  :root.dark ::selection {
    background: rgba(34, 197, 94, 0.4);
  }

  ::-webkit-scrollbar {
    width: 8px;
  }

  ::-webkit-scrollbar-track {
    background: rgba(0, 0, 0, 0.05);
  }

  ::-webkit-scrollbar-thumb {
    background: rgba(0, 0, 0, 0.15);
    border-radius: 4px;
  }

  ::-webkit-scrollbar-thumb:hover {
    background: rgba(0, 0, 0, 0.25);
  }

  :root.dark ::-webkit-scrollbar-track {
    background: rgba(255, 255, 255, 0.03);
  }

  :root.dark ::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.15);
  }

  :root.dark ::-webkit-scrollbar-thumb:hover {
    background: rgba(255, 255, 255, 0.25);
  }

  h1, h2, h3, h4 {
    line-height: 1.2;
    font-weight: 700;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    max-width: 100%;
    height: auto;
  }

  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .glass {
    background: var(--surface);
    backdrop-filter: blur(var(--blur-amount));
    -webkit-backdrop-filter: blur(var(--blur-amount));
    border: 1px solid var(--card-border);
    border-radius: var(--radius);
    transition: background var(--theme-transition), border-color var(--theme-transition), box-shadow var(--theme-transition);
  }

  .glass-strong {
    background: rgba(255, 255, 255, 0.5);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.6);
    border-radius: var(--radius);
  }

  :root.dark .glass-strong {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.12);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1.25rem;
    border-radius: 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 600;
    border: none;
    cursor: pointer;
    transition: all 0.2s ease;
    background: var(--accent-green);
    color: white;
  }

  .btn:hover {
    filter: brightness(1.15);
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(34, 197, 94, 0.3);
  }

  .btn:active {
    transform: translateY(0);
  }

  .btn-ghost {
    background: transparent;
    border: 1.5px solid rgba(0, 0, 0, 0.1);
    color: var(--text-primary);
  }

  :root.dark .btn-ghost {
    border-color: rgba(255, 255, 255, 0.15);
    color: var(--text-primary);
  }

  .btn-ghost:hover {
    background: rgba(0, 0, 0, 0.05);
    filter: none;
    box-shadow: none;
  }

  :root.dark .btn-ghost:hover {
    background: rgba(255, 255, 255, 0.08);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  .fade-in {
    animation: fadeIn 0.42s ease-out both;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 768px) {
    .container {
      padding: 0 1rem;
    }
  }
</style>
