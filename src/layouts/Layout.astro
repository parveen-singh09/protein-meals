---
export interface Props {
  title?: string;
  description?: string;
}

const { title = 'High Protein Valley - Discover Protein-Rich Foods', description = 'Explore 60+ high protein foods with complete macros, micros, prices, and HD images. The ultimate free resource for protein-rich nutrition.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="keywords" content="high protein foods, protein sources, nutrition, macros, muscle building, healthy eating" />
    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link href="https://unpkg.com/lucide-static@latest/font/lucide.css" rel="stylesheet" />
  </head>
  <body>
    <slot />

    <script>
      const savedTheme = localStorage.getItem('theme');
      if (savedTheme === 'dark' || (!savedTheme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      }
      requestAnimationFrame(() => {
        document.documentElement.classList.add('theme-ready');
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    --blur-amount: 15px;
    --glass-opacity: 0.15;
    --border-color: rgba(255, 255, 255, 0.2);
    --accent-blue: #0080FF;
    --accent-purple: #8B00FF;
    --accent-pink: #FF1493;
    --accent-teal: #20B2AA;
    --accent-green: #22c55e;
    --accent-lime: #84cc16;
    --bg-gradient-1: #d4edda;
    --bg-gradient-2: #e2efd9;
    --bg-gradient-3: #c8e6e3;
    --surface: rgba(180, 220, 180, 0.25);
    --surface-hover: rgba(180, 220, 180, 0.35);
    --text-primary: #1a2332;
    --text-secondary: #475569;
    --text-muted: #64748b;
    --card-bg: rgba(180, 220, 180, 0.2);
    --card-border: rgba(180, 220, 180, 0.3);
    --shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
    --radius: 0.75rem;
    --max-width: 1280px;
    --font-sans: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    --font-mono: 'JetBrains Mono', monospace;
    --theme-transition: 0.35s ease;
  }

  :root.dark {
    --bg-gradient-1: #0a1628;
    --bg-gradient-2: #0d2137;
    --bg-gradient-3: #0a1a28;
    --surface: rgba(255, 255, 255, 0.06);
    --surface-hover: rgba(255, 255, 255, 0.1);
    --card-bg: rgba(255, 255, 255, 0.04);
    --card-border: rgba(255, 255, 255, 0.08);
    --text-primary: #e8edf5;
    --text-secondary: #94a3b8;
    --text-muted: #64748b;
    --shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  html.theme-ready,
  html.theme-ready body {
    transition: background 0.35s ease, color 0.35s ease;
  }

  body {
    margin: 0;
    padding: 0;
    width: 100%;
    min-height: 100dvh;
    font-family: var(--font-sans);
    background: linear-gradient(135deg, var(--bg-gradient-1), var(--bg-gradient-2), var(--bg-gradient-3));
    background-attachment: fixed;
    color: var(--text-primary);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  html.theme-ready .glass {
    transition: background 0.35s ease, border-color 0.35s ease, box-shadow 0.35s ease;
  }

  ::selection {
    background: rgba(34, 197, 94, 0.35);
    color: white;
  }

  :root.dark ::selection {
    background: rgba(34, 197, 94, 0.4);
  }

  ::-webkit-scrollbar {
    width: 8px;
  }

  ::-webkit-scrollbar-track {
    background: rgba(0, 0, 0, 0.05);
  }

  ::-webkit-scrollbar-thumb {
    background: rgba(0, 0, 0, 0.15);
    border-radius: 4px;
  }

  ::-webkit-scrollbar-thumb:hover {
    background: rgba(0, 0, 0, 0.25);
  }

  :root.dark ::-webkit-scrollbar-track {
    background: rgba(255, 255, 255, 0.03);
  }

  :root.dark ::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.15);
  }

  :root.dark ::-webkit-scrollbar-thumb:hover {
    background: rgba(255, 255, 255, 0.25);
  }

  h1, h2, h3, h4 {
    line-height: 1.2;
    font-weight: 700;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    max-width: 100%;
    height: auto;
  }

  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .glass {
    background: var(--surface);
    backdrop-filter: blur(var(--blur-amount));
    -webkit-backdrop-filter: blur(var(--blur-amount));
    border: 1px solid var(--card-border);
    border-radius: var(--radius);
    transition: background var(--theme-transition), border-color var(--theme-transition), box-shadow var(--theme-transition);
  }

  .glass-strong {
    background: rgba(255, 255, 255, 0.5);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.6);
    border-radius: var(--radius);
  }

  :root.dark .glass-strong {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.12);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1.25rem;
    border-radius: 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 600;
    border: none;
    cursor: pointer;
    transition: all 0.2s ease;
    background: var(--accent-green);
    color: white;
  }

  .btn:hover {
    filter: brightness(1.15);
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(34, 197, 94, 0.3);
  }

  .btn:active {
    transform: translateY(0);
  }

  .btn-ghost {
    background: transparent;
    border: 1.5px solid rgba(0, 0, 0, 0.12);
    color: var(--text-primary);
  }

  :root.dark .btn-ghost {
    border-color: rgba(0, 0, 0, 0.12);
  }

  .btn-ghost:hover {
    background: rgba(0, 0, 0, 0.04);
    filter: none;
    box-shadow: none;
  }

  :root.dark .btn-ghost:hover {
    background: rgba(0, 0, 0, 0.04);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  .fade-in {
    animation: fadeIn 0.42s ease-out both;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 768px) {
    .container {
      padding: 0 1rem;
    }
  }
</style>
