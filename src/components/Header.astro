---
import { categories } from "../data/foods";
import LanguageSwitcher from "./LanguageSwitcher.astro";
---

<header class="header">
  <div class="container header-inner">
    <button
      class="menu-toggle"
      id="menuToggle"
      aria-label="Toggle menu"
    >
      <svg
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <line x1="3" y1="6" x2="21" y2="6"></line><line
          x1="3"
          y1="12"
          x2="21"
          y2="12"></line><line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>
    <a href="/" class="logo">
      <img class="logo-img" src="/favicon-96x96.png" alt="HighProtein Foodz" width="27" height="27" style="border-radius: 8px;" />
      <span class="logo-text">HighProteinFoodz</span>
    </a>

    <nav class="nav-desktop">
      <a href="/" class="nav-link active" data-i18n="nav.home">Home</a>
      <a href="#foods" class="nav-link" data-i18n="nav.allFoods">All Foods</a>
      {
        categories
          .filter((c) => c.id !== "all")
          .map((c) => (
            <a href={`#${c.id}`} class="nav-link" data-i18n={`categories.${c.id}`}>
              {c.label}
            </a>
          ))
      }
    </nav>

    <div class="header-actions">
      <LanguageSwitcher />
      <button
        class="theme-toggle"
        id="themeToggle"
        aria-label="Toggle theme"
      >
        <svg
          class="sun-icon"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <circle cx="12" cy="12" r="5"></circle><line
            x1="12"
            y1="1"
            x2="12"
            y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line
            x1="4.22"
            y1="4.22"
            x2="5.64"
            y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"
          ></line><line x1="1" y1="12" x2="3" y2="12"></line><line
            x1="21"
            y1="12"
            x2="23"
            y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"
          ></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
        </svg>
        <svg
          class="moon-icon"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
      </button>
    </div>
  </div>
</header>

<div class="mobile-nav" id="mobileNav">
  <div class="mobile-nav-header">
    <button class="mobile-nav-hamburger" id="mobileNavHamburger" aria-label="Close menu">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>
    <span class="mobile-nav-title" data-i18n="nav.categories">Categories</span>
  </div>
  <a href="#foods" class="mobile-link" data-i18n="nav.allFoods">All Foods</a>
  {
    categories
      .filter((c) => c.id !== "all")
      .map((c) => (
        <a href={`#${c.id}`} class="mobile-link" data-i18n={`categories.${c.id}`}>
          {c.label}
        </a>
      ))
  }
</div>
<div class="mobile-overlay" id="mobileOverlay"></div>

<script>
  const themeToggle = document.getElementById("themeToggle");
  const menuToggle = document.getElementById("menuToggle");
  const mobileNav = document.getElementById("mobileNav");
  const mobileOverlay = document.getElementById("mobileOverlay");
  const root = document.documentElement;

  themeToggle?.addEventListener("click", () => {
    root.classList.toggle("dark");
    localStorage.setItem(
      "theme",
      root.classList.contains("dark") ? "dark" : "light",
    );
  });

  function toggleMobileNav() {
    const isOpen = mobileNav?.classList.contains("open");
    mobileNav?.classList.toggle("open");
    mobileOverlay?.classList.toggle("open");
    document.body.style.overflow = isOpen ? "" : "hidden";
  }

  function closeMobileNav() {
    mobileNav?.classList.remove("open");
    mobileOverlay?.classList.remove("open");
    document.body.style.overflow = "";
  }

  menuToggle?.addEventListener("click", toggleMobileNav);
  mobileOverlay?.addEventListener("click", closeMobileNav);

  const mobileNavHamburger = document.getElementById("mobileNavHamburger");
  mobileNavHamburger?.addEventListener("click", closeMobileNav);

  document.querySelectorAll(".mobile-link").forEach((link) => {
    link.addEventListener("click", closeMobileNav);
  });
</script>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.2);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.25);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
  }

  html.theme-ready .header {
    transition:
      background 0.35s ease,
      border-color 0.35s ease,
      box-shadow 0.35s ease;
  }

  :root.dark .header {
    background: rgba(255, 255, 255, 0.04);
    border-bottom-color: rgba(255, 255, 255, 0.08);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
    gap: 1rem;
  }

  .logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo-img {
    display: block;
  }

  .logo-text {
    display: none;
    font-weight: 800;
    font-size: 1.0625rem;
    letter-spacing: -0.03em;
    background: linear-gradient(135deg, var(--accent-emerald), var(--accent-teal));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    text-transform: none;
  }

  .nav-desktop {
    display: none;
    align-items: center;
    gap: 0.25rem;
  }

  .nav-link {
    padding: 0.5rem 0.75rem;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-secondary);
    transition: all 0.2s;
    white-space: nowrap;
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--text-primary);
    background: rgba(255, 255, 255, 0.06);
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    cursor: pointer;
    color: var(--text-secondary);
    background: none;
    border: none;
    transition: color 0.2s;
  }

  .theme-toggle:hover {
    color: var(--text-primary);
  }

  .sun-icon {
    display: none;
  }
  .moon-icon {
    display: block;
  }
  :root.dark .sun-icon {
    display: block;
  }
  :root.dark .moon-icon {
    display: none;
  }

  .theme-toggle .sun-icon,
  .theme-toggle .moon-icon {
    transition:
      opacity var(--theme-transition),
      transform var(--theme-transition);
  }

  .menu-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    cursor: pointer;
    color: var(--text-secondary);
    background: none;
    border: none;
    transition: color 0.2s;
  }

  .menu-toggle:hover {
    color: var(--text-primary);
  }

  .mobile-nav {
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    width: min(320px, 80vw);
    background: rgba(255, 255, 255, 0.3);
    backdrop-filter: blur(24px) saturate(1.5);
    -webkit-backdrop-filter: blur(24px) saturate(1.5);
    border-left: none;
    border-right: 1px solid rgba(255, 255, 255, 0.4);
    z-index: 200;
    display: flex;
    flex-direction: column;
    padding: 1rem;
    gap: 0.25rem;
    transform: translateX(-100%);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), background var(--theme-transition), border-color var(--theme-transition);
    box-shadow: 8px 0 40px rgba(0, 0, 0, 0.12);
  }

  :root.dark .mobile-nav {
    background: rgba(255, 255, 255, 0.06);
    border-right-color: rgba(255, 255, 255, 0.12);
  }

  .mobile-nav.open {
    transform: translateX(0);
  }

  .mobile-nav-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding-bottom: 0.75rem;
    margin-bottom: 0.5rem;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
  }

  :root.dark .mobile-nav-header {
    border-bottom-color: rgba(255, 255, 255, 0.06);
  }

  .mobile-nav-title {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
    color: var(--text-muted);
  }

  .mobile-nav-hamburger {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    cursor: pointer;
    color: var(--text-secondary);
    background: none;
    border: none;
    padding: 0;
  }

  .mobile-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.4);
    z-index: 199;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .mobile-overlay.open {
    opacity: 1;
    pointer-events: auto;
  }

  .mobile-link {
    padding: 0.75rem;
    border-radius: 0.5rem;
    font-size: 1rem;
    font-weight: 500;
    color: var(--text-secondary);
    transition: all 0.2s;
    text-decoration: none;
  }

  .mobile-link:hover {
    color: var(--text-primary);
    background: rgba(255, 255, 255, 0.06);
  }

  @media (max-width: 1199px) {
    .header-inner {
      gap: 0.25rem;
    }
    .logo {
      margin-right: auto;
    }
    .header-actions {
      gap: 0.25rem;
    }
    .logo-img {
      display: none;
    }
    .logo-text {
      display: block;
    }
  }

  @media (min-width: 1200px) {
    .header-inner {
      position: relative;
      justify-content: center;
    }
    .logo {
      position: absolute;
      left: 1.5rem;
    }
    .header-actions {
      position: absolute;
      right: 1.5rem;
    }
    .menu-toggle {
      display: none;
    }
    .mobile-nav {
      display: none !important;
    }
    .mobile-overlay {
      display: none !important;
    }
    .nav-desktop {
      display: flex;
      gap: 0.375rem;
    }
    .nav-link {
      padding: 0.5rem 0.625rem;
      font-size: 0.8125rem;
    }
  }

  @media (min-width: 1360px) {
    .nav-desktop {
      gap: 0.625rem;
    }
    .nav-link {
      padding: 0.5rem 0.875rem;
      font-size: 0.875rem;
    }
  }
</style>
