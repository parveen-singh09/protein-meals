---
import { categories, sortOptions } from "../data/foods";
import LanguageSwitcher from "./LanguageSwitcher.astro";

const pathname = Astro.url.pathname;
const isFoodsPage = pathname.replace(/\/$/, "") === "/foods";
const isHomePage = pathname.replace(/\/$/, "") === "";
---

<header class={`header ${isHomePage ? "is-home" : ""}`}>
  <div class="container header-inner">
    <button
      class="menu-toggle"
      id="menuToggle"
      aria-label="Toggle menu"
    >
      <svg
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <line x1="3" y1="6" x2="21" y2="6"></line><line
          x1="3"
          y1="12"
          x2="21"
          y2="12"></line><line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>
    <a href="/" class="logo">
      <img class={`logo-img ${isFoodsPage ? "show-on-foods" : ""}`} src="/favicon-96x96.png" alt="HighProtein Foodz" width="27" height="27" style="border-radius: 8px;" />
      <span class={`logo-text ${isFoodsPage ? "hidden-on-foods" : ""}`}>HighProteinFoodz</span>
    </a>

    {isFoodsPage ? (
      <div class="header-filters-container">
        <div class="search-wrapper">
          <input
            id="search-input"
            type="text"
            class="search-input"
            placeholder="Search foods..."
            data-i18n="foodgrid.searchPlaceholder"
          />
          <button
            class="search-clear"
            id="search-clear"
            aria-label="Clear search"
          >
            &times;
          </button>
        </div>

        <div class="header-filter-dropdowns">
          <button class="mobile-filter-btn" id="mobileSortBtn" aria-label="Sort">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="m3 16 4 4 4-4"></path><path d="M7 20V4"></path><path d="m13 8 4-4 4 4"></path><path d="M17 20V4"></path>
            </svg>
          </button>
          <button class="mobile-filter-btn" id="mobileCategoryBtn" aria-label="Category">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="7" height="7" x="3" y="3" rx="1"></rect><rect width="7" height="7" x="14" y="3" rx="1"></rect><rect width="7" height="7" x="3" y="14" rx="1"></rect><rect width="7" height="7" x="14" y="14" rx="1"></rect>
            </svg>
          </button>
          <div class="custom-dropdown" id="sortDropdownContainer">
            <button
              class="dropdown-trigger"
              id="sortDropdownTrigger"
              aria-haspopup="listbox"
              aria-expanded="false"
            >
              <span id="sortTriggerText" data-i18n="sort.highestProtein"
                >Highest Protein</span
              >
              <svg
                class="chevron-icon"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"><path d="m6 9 6 6 6-6"></path></svg
              >
            </button>
            <div class="dropdown-menu" role="listbox">
              {
                sortOptions.map((opt) => {
                  const i18nKey = {
                    "protein-desc": "sort.highestProtein",
                    "protein-asc": "sort.lowestProtein",
                    "calories-desc": "sort.highestCalories",
                    "calories-asc": "sort.lowestCalories",
                    "protein-per-price": "sort.bestProteinPerPrice",
                  }[opt.id];
                  return (
                    <button
                      class="dropdown-item"
                      role="option"
                      data-value={opt.id}
                      data-i18n={i18nKey}
                    >
                      {opt.label}
                    </button>
                  );
                })
              }
            </div>
          </div>

          <div class="custom-dropdown" id="categoryDropdownContainer">
            <button
              class="dropdown-trigger"
              id="categoryDropdownTrigger"
              aria-haspopup="listbox"
              aria-expanded="false"
            >
              <span id="categoryTriggerText" data-i18n="nav.allFoods"
                >All Foods</span
              >
              <svg
                class="chevron-icon"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"><path d="m6 9 6 6 6-6"></path></svg
              >
            </button>
            <div class="dropdown-menu" role="listbox">
              <button
                class="dropdown-item"
                role="option"
                data-value="all"
                data-i18n="nav.allFoods">All Foods</button
              >
              <button
                class="dropdown-item"
                role="option"
                data-value="meat"
                data-i18n="categories.meat">Meat & Poultry</button
              >
              <button
                class="dropdown-item"
                role="option"
                data-value="seafood"
                data-i18n="categories.seafood">Fish & Seafood</button
              >
              <button
                class="dropdown-item"
                role="option"
                data-value="dairy"
                data-i18n="categories.dairy">Dairy & Eggs</button
              >
              <button
                class="dropdown-item"
                role="option"
                data-value="plant"
                data-i18n="categories.plant">Plant-Based</button
              >
              <button
                class="dropdown-item"
                role="option"
                data-value="supplements"
                data-i18n="categories.supplements">Supplements</button
              >
            </div>
          </div>
        </div>
      </div>

      <div class="mobile-sort-dropdown" id="mobileSortDropdown">
        <div class="mobile-filter-section">
          <h4 class="mobile-filter-title" data-i18n="sort.sortBy">Sort By</h4>
          <div class="mobile-filter-options" id="mobileSortOptions">
            {
              sortOptions.map((opt) => {
                const i18nKey = {
                  "protein-desc": "sort.highestProtein",
                  "protein-asc": "sort.lowestProtein",
                  "calories-desc": "sort.highestCalories",
                  "calories-asc": "sort.lowestCalories",
                  "protein-per-price": "sort.bestProteinPerPrice",
                }[opt.id];
                return (
                  <button
                    class="mobile-filter-option"
                    role="option"
                    data-value={opt.id}
                    data-i18n={i18nKey}
                  >
                    {opt.label}
                  </button>
                );
              })
            }
          </div>
        </div>
      </div>
      <div class="mobile-category-dropdown" id="mobileCategoryDropdown">
        <div class="mobile-filter-section">
          <h4 class="mobile-filter-title" data-i18n="nav.categories">Category</h4>
          <div class="mobile-filter-options" id="mobileCategoryOptions">
            <button class="mobile-filter-option" role="option" data-value="all" data-i18n="nav.allFoods">All Foods</button>
            <button class="mobile-filter-option" role="option" data-value="meat" data-i18n="categories.meat">Meat & Poultry</button>
            <button class="mobile-filter-option" role="option" data-value="seafood" data-i18n="categories.seafood">Fish & Seafood</button>
            <button class="mobile-filter-option" role="option" data-value="dairy" data-i18n="categories.dairy">Dairy & Eggs</button>
            <button class="mobile-filter-option" role="option" data-value="plant" data-i18n="categories.plant">Plant-Based</button>
            <button class="mobile-filter-option" role="option" data-value="supplements" data-i18n="categories.supplements">Supplements</button>
          </div>
        </div>
      </div>
    ) : (
      <nav class="nav-desktop">
        <a href="/" class={`nav-link ${isHomePage ? "active" : ""}`} data-i18n="nav.home">Home</a>
        <a href={isFoodsPage ? "#foods" : "/foods"} class={`nav-link ${isFoodsPage ? "active" : ""}`} data-i18n="nav.allFoods">All Foods</a>
        {
          categories
            .filter((c) => c.id !== "all")
            .map((c) => (
              <a href={isFoodsPage ? `#${c.id}` : `/foods#${c.id}`} class="nav-link" data-i18n={`categories.${c.id}`}>
                {c.label}
              </a>
            ))
        }
      </nav>
    )}

    <div class="header-actions">
      <LanguageSwitcher class={!isHomePage ? "hidden-on-foods-mobile" : ""} />
      <button
        class={`theme-toggle ${!isHomePage ? "hidden-on-foods-mobile" : ""}`}
        id="themeToggle"
        aria-label="Toggle theme"
      >
        <svg
          class="sun-icon"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <circle cx="12" cy="12" r="5"></circle><line
            x1="12"
            y1="1"
            x2="12"
            y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line
            x1="4.22"
            y1="4.22"
            x2="5.64"
            y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"
          ></line><line x1="1" y1="12" x2="3" y2="12"></line><line
            x1="21"
            y1="12"
            x2="23"
            y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"
          ></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
        </svg>
        <svg
          class="moon-icon"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
      </button>
    </div>
  </div>
</header>

<div class="mobile-nav" id="mobileNav">
  <div class="mobile-nav-header">
    <button class="mobile-nav-hamburger" id="mobileNavHamburger" aria-label="Close menu">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>
    <span class="mobile-nav-title" data-i18n="nav.categories">Categories</span>
    <div class="mobile-nav-actions">
      <button class="theme-toggle" id="mobileThemeToggle" aria-label="Toggle theme">
        <svg class="sun-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
        </svg>
        <svg class="moon-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
      </button>
    </div>
  </div>
  <a href="/" class="mobile-link" data-i18n="nav.home">Home</a>
  <a href={isFoodsPage ? "#foods" : "/foods"} class="mobile-link" data-i18n="nav.allFoods">All Foods</a>
  {
    categories
      .filter((c) => c.id !== "all")
      .map((c) => (
        <a href={isFoodsPage ? `#${c.id}` : `/foods#${c.id}`} class="mobile-link" data-i18n={`categories.${c.id}`}>
          {c.label}
        </a>
      ))
  }
</div>
<div class="mobile-overlay" id="mobileOverlay"></div>

<script>
  const themeToggle = document.getElementById("themeToggle");
  const menuToggle = document.getElementById("menuToggle");
  const mobileNav = document.getElementById("mobileNav");
  const mobileOverlay = document.getElementById("mobileOverlay");
  const root = document.documentElement;

  themeToggle?.addEventListener("click", () => {
    root.classList.toggle("dark");
    localStorage.setItem(
      "theme",
      root.classList.contains("dark") ? "dark" : "light",
    );
  });

  const mobileThemeToggle = document.getElementById("mobileThemeToggle");
  mobileThemeToggle?.addEventListener("click", () => {
    root.classList.toggle("dark");
    localStorage.setItem(
      "theme",
      root.classList.contains("dark") ? "dark" : "light",
    );
  });

  function toggleMobileNav() {
    const isOpen = mobileNav?.classList.contains("open");
    mobileNav?.classList.toggle("open");
    mobileOverlay?.classList.toggle("open");
    document.body.style.overflow = isOpen ? "" : "hidden";
  }

  function closeMobileNav() {
    mobileNav?.classList.remove("open");
    mobileOverlay?.classList.remove("open");
    document.body.style.overflow = "";
  }

  menuToggle?.addEventListener("click", toggleMobileNav);
  mobileOverlay?.addEventListener("click", closeMobileNav);

  const mobileNavHamburger = document.getElementById("mobileNavHamburger");
  mobileNavHamburger?.addEventListener("click", closeMobileNav);

  document.querySelectorAll(".mobile-link").forEach((link) => {
    link.addEventListener("click", closeMobileNav);
  });

  const mobileSortBtn = document.getElementById("mobileSortBtn");
  const mobileSortDropdown = document.getElementById("mobileSortDropdown");
  const mobileCategoryBtn = document.getElementById("mobileCategoryBtn");
  const mobileCategoryDropdown = document.getElementById("mobileCategoryDropdown");

  mobileSortBtn?.addEventListener("click", (e) => {
    e.stopPropagation();
    mobileSortDropdown?.classList.toggle("open");
    mobileCategoryDropdown?.classList.remove("open");
  });

  mobileCategoryBtn?.addEventListener("click", (e) => {
    e.stopPropagation();
    mobileCategoryDropdown?.classList.toggle("open");
    mobileSortDropdown?.classList.remove("open");
  });

  document.addEventListener("click", (e) => {
    if (!mobileSortDropdown?.contains(e.target) && !mobileSortBtn?.contains(e.target) &&
        !mobileCategoryDropdown?.contains(e.target) && !mobileCategoryBtn?.contains(e.target)) {
      mobileSortDropdown?.classList.remove("open");
      mobileCategoryDropdown?.classList.remove("open");
    }
  });
</script>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background-color: rgba(255, 255, 255, 0.2);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.25);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
  }

  html.theme-ready .header {
    transition:
      background-color 0.35s ease,
      border-color 0.35s ease,
      box-shadow 0.35s ease;
  }

  :root.dark .header {
    background-color: rgba(15, 23, 42, 0.3);
    border-bottom-color: rgba(255, 255, 255, 0.08);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
    gap: 1rem;
  }

  .logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo-img {
    display: block;
  }

  .logo-text {
    display: none;
    font-weight: 800;
    font-size: 1.0625rem;
    letter-spacing: -0.03em;
    background: linear-gradient(135deg, var(--accent-emerald), var(--accent-teal));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    text-transform: none;
  }

  .nav-desktop {
    display: none;
    align-items: center;
    gap: 0.25rem;
  }

  .nav-link {
    padding: 0.5rem 0.75rem;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-secondary);
    transition: all 0.2s;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--text-primary);
    background: rgba(255, 255, 255, 0.06);
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    cursor: pointer;
    color: var(--text-secondary);
    background: none;
    border: none;
    transition: color 0.2s;
  }

  .theme-toggle:hover {
    color: var(--text-primary);
  }

  .sun-icon {
    display: none;
  }
  .moon-icon {
    display: block;
  }
  :root.dark .sun-icon {
    display: block;
  }
  :root.dark .moon-icon {
    display: none;
  }

  .theme-toggle .sun-icon,
  .theme-toggle .moon-icon {
    transition:
      opacity var(--theme-transition),
      transform var(--theme-transition);
  }

  .menu-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    cursor: pointer;
    color: var(--text-secondary);
    background: none;
    border: none;
    transition: color 0.2s;
  }

  .menu-toggle:hover {
    color: var(--text-primary);
  }

  .mobile-nav {
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    width: min(320px, 80vw);
    background: rgba(255, 255, 255, 0.3);
    backdrop-filter: blur(24px) saturate(1.5);
    -webkit-backdrop-filter: blur(24px) saturate(1.5);
    border-left: none;
    border-right: 1px solid rgba(255, 255, 255, 0.4);
    z-index: 200;
    display: flex;
    flex-direction: column;
    padding: 1rem;
    gap: 0.25rem;
    transform: translateX(-100%);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), background var(--theme-transition), border-color var(--theme-transition);
    box-shadow: 8px 0 40px rgba(0, 0, 0, 0.12);
  }

  :root.dark .mobile-nav {
    background: rgba(255, 255, 255, 0.06);
    border-right-color: rgba(255, 255, 255, 0.12);
  }

  .mobile-nav.open {
    transform: translateX(0);
  }

  .mobile-nav-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding-bottom: 0.75rem;
    margin-bottom: 0.5rem;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
  }

  :root.dark .mobile-nav-header {
    border-bottom-color: rgba(255, 255, 255, 0.06);
  }

  .mobile-nav-title {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
    color: var(--text-muted);
  }

  .mobile-nav-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-left: auto;
  }

  .mobile-nav-actions .theme-toggle {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-secondary);
    background: none;
    border: none;
    cursor: pointer;
  }

  .mobile-nav-actions .theme-toggle:hover {
    color: var(--text-primary);
  }

  .mobile-nav-actions .lang-switcher-wrapper {
    display: flex;
    align-items: center;
  }

  .mobile-nav-actions .lang-switcher {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    padding: 0;
    gap: 0;
  }

  .mobile-nav-actions .lang-label {
    display: none;
  }

  .mobile-nav-hamburger {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    cursor: pointer;
    color: var(--text-secondary);
    background: none;
    border: none;
    padding: 0;
  }

  .mobile-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.4);
    z-index: 199;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .mobile-overlay.open {
    opacity: 1;
    pointer-events: auto;
  }

  .mobile-link {
    padding: 0.75rem;
    border-radius: 0.5rem;
    font-size: 1rem;
    font-weight: 500;
    color: var(--text-secondary);
    transition: all 0.2s;
    text-decoration: none;
  }

  .mobile-link:hover {
    color: var(--text-primary);
    background: rgba(255, 255, 255, 0.06);
  }

  @media (max-width: 1023px) {
    .header-inner {
      gap: 0.25rem;
    }
    .logo {
      margin-right: auto;
    }
    .header-actions {
      gap: 0.25rem;
    }
    .logo-img {
      display: none;
    }
    .logo-text {
      display: block;
    }
  }

  @media (min-width: 1024px) {
    .header-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
    }
    .menu-toggle {
      display: none;
    }
    .mobile-nav {
      display: none !important;
    }
    .mobile-overlay {
      display: none !important;
    }
    .nav-desktop {
      display: flex;
      align-items: center;
      justify-content: center;
      flex-grow: 1;
      gap: 0.25rem;
      flex-wrap: nowrap;
      min-width: 0;
    }
    .nav-link {
      padding: 0.4rem 0.5rem;
      font-size: 0.8rem;
      max-width: 110px;
    }
  }

  @media (min-width: 1280px) {
    .nav-desktop {
      gap: 0.375rem;
    }
    .nav-link {
      padding: 0.5rem 0.625rem;
      font-size: 0.8125rem;
      max-width: 140px;
    }
  }

  @media (min-width: 1440px) {
    .nav-desktop {
      gap: 0.5rem;
    }
    .nav-link {
      padding: 0.5rem 0.75rem;
      font-size: 0.85rem;
      max-width: 180px;
    }
  }

  /* Header Dropdown & Filters Styles */
  .header-filters-container {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-grow: 1;
    max-width: 680px;
    margin: 0 1rem;
    min-width: 0;
  }

  .header-filters-container .search-wrapper {
    flex: 1.8;
    min-width: 180px;
    position: relative;
  }

  .header-filter-dropdowns {
    display: flex;
    gap: 0.5rem;
    flex: 1.6;
    min-width: 220px;
  }

  .custom-dropdown {
    position: relative;
    flex: 1;
    min-width: 0;
  }

  .dropdown-trigger {
    display: grid;
