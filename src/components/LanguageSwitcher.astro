---
import { languages } from "../i18n";
---

<div class="lang-switcher-wrapper" id="langSwitcherWrapper">
  <button class="lang-switcher" id="langSwitcher" aria-label="Switch language">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="10"></circle>
      <line x1="2" y1="12" x2="22" y2="12"></line>
      <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
    </svg>
    <span class="lang-flag" id="langFlag">🇬🇧</span>
  </button>
  <div class="lang-dropdown glass-strong" id="langDropdown">
    {
      languages.map((lang) => (
        <button class="lang-option" data-lang={lang.code}>
          <span class="lang-option-flag">{lang.flag}</span>
          <span class="lang-option-name">{lang.name}</span>
        </button>
      ))
    }
  </div>
</div>

<style>
  .lang-switcher-wrapper {
    position: relative;
  }

  .lang-switcher {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.3rem;
    height: 36px;
    cursor: pointer;
    color: var(--text-secondary);
    background: none;
    border: none;
    padding: 0 0.25rem;
    transition: color 0.2s;
  }

  .lang-switcher:hover {
    color: var(--text-primary);
  }

  .lang-flag {
    font-size: 1rem;
    line-height: 1;
  }

  .lang-dropdown {
    position: absolute;
    top: 100%;
    right: 0;
    margin-top: 0.375rem;
    background: rgba(255, 255, 255, 0.28);
    backdrop-filter: blur(24px) saturate(1.5);
    -webkit-backdrop-filter: blur(24px) saturate(1.5);
    border: 1px solid rgba(255, 255, 255, 0.45);
    border-radius: 0.75rem;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
    display: none;
    flex-direction: column;
    padding: 0.375rem;
    gap: 0.125rem;
    min-width: 170px;
    max-height: 320px;
    overflow-y: auto;
    z-index: 300;
  }

  :root.dark .lang-dropdown {
    background: rgba(255, 255, 255, 0.07);
    backdrop-filter: blur(24px) saturate(1.5);
    -webkit-backdrop-filter: blur(24px) saturate(1.5);
    border-color: rgba(255, 255, 255, 0.1);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
  }

  .lang-switcher-wrapper.open .lang-dropdown {
    display: flex;
  }

  .lang-option-flag {
    font-size: 1.1rem;
    line-height: 1;
  }

  .lang-option {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.75rem;
    border: none;
    background: none;
    border-radius: 0.5rem;
    cursor: pointer;
    color: var(--text-secondary);
    transition: all 0.15s;
    font-size: 0.8125rem;
    text-align: left;
    width: 100%;
  }

  .lang-option:hover {
    background: var(--surface-hover);
    color: var(--text-primary);
  }

  .lang-option-name {
    color: var(--text-muted);
  }

  .lang-option:hover .lang-option-name {
    color: var(--text-secondary);
  }
</style>
