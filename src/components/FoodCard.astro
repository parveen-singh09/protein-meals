---
export interface Props {
  food: {
    id: string;
    name: string;
    category: string;
    protein: number;
    calories: number;
    carbs: number;
    fat: number;
    fiber: number;
    price: number;
    priceUnit: string;
    serving: string;
    ageGroups: string[];
    availability: string;
    image: string;
    micros: Record<string, number | undefined>;
    description: string;
    type: string;
    completeProtein: boolean;
    bioavailability: number;
    aminoAcids: number;
    tags: string[];
  };
  index: number;
}

const { food, index } = Astro.props;

const proteinBarPercent = Math.min((food.protein / 100) * 100, 100);

const priceValue =
  food.priceUnit === "lb" ? (food.price / 453.6) * 100 : food.price;
const proteinPerPrice = food.protein / (priceValue || 1);

const weightUnits = ["lb", "pound", "ounce", "oz"];
const isWeightUnit = weightUnits.some((u) => food.priceUnit.includes(u));

const priceLabel = isWeightUnit
  ? "avg price / 100g"
  : `avg price / ${food.priceUnit}`;
const displayPrice = isWeightUnit
  ? (food.price / 453.6).toFixed(2)
  : (food.price / 100).toFixed(2);

const categoryLabels: Record<string, string> = {
  meat: "Meat & Poultry",
  seafood: "Fish & Seafood",
  dairy: "Dairy & Eggs",
  plant: "Plant-Based",
  supplements: "Supplements",
};

const microLabels: Record<string, string> = {
  vitaminA: "Vitamin A",
  vitaminB6: "Vitamin B6",
  vitaminB12: "Vitamin B12",
  vitaminC: "Vitamin C",
  vitaminD: "Vitamin D",
  vitaminE: "Vitamin E",
  vitaminK: "Vitamin K",
  calcium: "Calcium",
  iron: "Iron",
  magnesium: "Magnesium",
  zinc: "Zinc",
  selenium: "Selenium",
  potassium: "Potassium",
  phosphorus: "Phosphorus",
  omega3: "Omega-3",
  choline: "Choline",
  folate: "Folate",
  niacin: "Niacin",
  riboflavin: "Riboflavin",
  thiamin: "Thiamin",
  copper: "Copper",
  manganese: "Manganese",
  glycine: "Glycine",
  proline: "Proline",
  hydroxyproline: "Hydroxyproline",
  pantothenicAcid: "Pantothenic Acid",
  iodine: "Iodine",
  sodium: "Sodium",
};

const mcgKeys = new Set([
  "vitaminA", "vitaminD", "vitaminK", "folate", "vitaminB12", "selenium",
]);

function microValue(v: number, key: string): string {
  if (v === 0) return "0";

  if (mcgKeys.has(key)) {
    // Some data stores µg nutrients in mg (e.g., salmon D: 0.012 mg = 12 µg)
    if (v < 0.1) v = v * 1000;
    if (v >= 1000) return (v / 1000).toFixed(1) + "mg";
    return v.toFixed(v < 1 ? 1 : 0) + "µg";
  }

  if (v >= 1000) return (v / 1000).toFixed(1) + "g";
  if (v >= 1) return v.toFixed(v >= 10 ? 1 : 2) + "mg";
  return (v * 1000).toFixed(v * 1000 >= 1 ? 0 : 1) + "µg";
}
---

<article
  class="food-card glass"
  style={`animation-delay: ${index * 80}ms`}
  data-protein={food.protein}
  data-calories={food.calories}
  data-protein-per-price={proteinPerPrice}
  data-name={food.name.toLowerCase()}
  data-category={food.category}
  data-description={food.description.toLowerCase()}
>
  <div class="card-row">
    <div class="card-left">
      <div class="card-image">
        <img
          src={food.image}
          alt={food.name}
          loading={index < 12 ? "eager" : "lazy"}
        />
        <div class="card-category">
          {categoryLabels[food.category] || food.category}
        </div>
      </div>

      <div class="card-body">
        <h3 class="card-title">{food.name}</h3>
        <p class="card-desc">{food.description}</p>

        <div class="macro-bar">
          <div class="macro-bar-label">
            <span>Protein</span>
            <span class="macro-value highlight"
              >{food.protein}g / {food.serving.replace(/\(.*\)/, "").trim()}</span
            >
          </div>
          <div class="macro-bar-track">
            <div class="macro-bar-fill" style={`width: ${proteinBarPercent}%`}>
            </div>
          </div>
        </div>

        <div class="macro-grid">
          <div class="macro-item">
            <span>{food.calories}</span>
            <small>Calories</small>
          </div>
          <div class="macro-item">
            <span>{food.carbs}g</span>
            <small>Carbs</small>
          </div>
          <div class="macro-item">
            <span>{food.fat}g</span>
            <small>Fat</small>
          </div>
          <div class="macro-item">
            <span>{food.fiber}g</span>
            <small>Fiber</small>
          </div>
        </div>

        <div class="card-stats">
          <div class="stat">
            <span class="stat-value">${displayPrice}</span>
            <span class="stat-label">Per {isWeightUnit ? "100g" : food.priceUnit}</span>
          </div>
          <div class="stat">
            <span class="stat-value">{food.bioavailability}%</span>
            <span class="stat-label">Bioavailability</span>
          </div>
          <div class="stat">
            <span class="stat-value">{food.aminoAcids}</span>
            <span class="stat-label">Amino Acids</span>
          </div>
        </div>
      </div>
    </div>

    <div class="card-right">
      <div class="micro-content">
        {
          Object.entries(food.micros)
            .filter(([, v]) => v != null && v !== 0)
            .map(([key, val]) => (
              <span class="micro-item">
                {microLabels[key] || key}
                <span class="micro-value">{microValue(val!, key)}</span>
              </span>
            ))
        }
      </div>
    </div>
  </div>
</article>

<style>
  .card-row {
    display: flex;
  }

  .card-left {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-width: 0;
    padding: 1.25rem;
    gap: 1.25rem;
  }

  .card-right {
    flex: 0 0 200px;
    padding: 1.25rem;
    border-left: 1px solid rgba(255, 255, 255, 0.12);
    display: flex;
    flex-direction: column;
  }

  :root.dark .card-right {
    border-color: rgba(255, 255, 255, 0.06);
  }

  .food-card {
    overflow: hidden;
    transition: all 0.3s ease;
    animation: fadeIn 0.42s ease-out both;
    background: rgba(255, 255, 255, 0.2);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.25);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
  }

  :root.dark .food-card {
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-color: rgba(255, 255, 255, 0.08);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
  }

  .food-card:hover {
    transform: scale(1.02);
    box-shadow: 0 12px 40px rgba(34, 197, 94, 0.15);
  }

  :root.dark .food-card:hover {
    box-shadow: 0 12px 40px rgba(34, 197, 94, 0.08);
  }

  .card-image {
    position: relative;
    height: 180px;
    border-radius: 0.5rem;
    overflow: hidden;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .card-category {
    position: absolute;
    bottom: 0.75rem;
    left: 0.75rem;
    font-size: 0.7rem;
    font-weight: 500;
    padding: 0.25rem 0.625rem;
    border-radius: 0.25rem;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: rgba(255, 255, 255, 0.9);
  }

  .card-body {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .card-title {
    margin: 0;
    font-size: 1.0625rem;
    font-weight: 700;
    line-height: 1.3;
  }

  .card-desc {
    margin: 0;
    font-size: 0.8125rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  .macro-bar {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .macro-bar-label {
    display: flex;
    justify-content: space-between;
    font-size: 0.75rem;
    color: var(--text-secondary);
  }

  .macro-value.highlight {
    color: var(--accent-teal);
    font-weight: 600;
    font-family: var(--font-mono);
  }

  .macro-bar-track {
    height: 6px;
    background: rgba(0, 0, 0, 0.06);
    border-radius: 3px;
    overflow: hidden;
  }

  :root.dark .macro-bar-track {
    background: rgba(255, 255, 255, 0.06);
  }

  .macro-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--accent-emerald), var(--accent-green-light));
    border-radius: 3px;
    transition: width 0.6s ease;
  }

  .macro-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .macro-grid .macro-item {
    flex: 1 0 60px;
    min-width: 0;
  }

  .macro-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.125rem;
    padding: 0.5rem;
    border-radius: 0.375rem;
    background: rgba(255, 255, 255, 0.08);
    font-size: 0.8125rem;
    font-weight: 600;
    font-family: var(--font-mono);
  }

  :root.dark .macro-item {
    background: rgba(255, 255, 255, 0.03);
  }

  .macro-item svg {
    color: var(--text-muted);
    width: 14px;
    height: 14px;
  }

  .macro-item small {
    font-size: 0.6rem;
    color: var(--text-muted);
    font-family: var(--font-sans);
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .card-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    padding: 0.75rem;
    border-radius: 0.5rem;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.12);
  }

  .card-stats .stat {
    flex: 1 0 70px;
    min-width: 0;
  }

  :root.dark .card-stats {
    background: rgba(255, 255, 255, 0.03);
    border-color: rgba(255, 255, 255, 0.06);
  }

  .stat {
    text-align: center;
  }

  .stat-value {
    display: block;
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--text-primary);
    font-family: var(--font-mono);
  }

  .stat-label {
    font-size: 0.6rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .micro-content {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    column-gap: 0.25rem;
    row-gap: 0.125rem;
    align-items: center;
    padding: 0.5rem 0.75rem;
    border-radius: 0.375rem;
    background: rgba(255, 255, 255, 0.2);
  }

  :root.dark .micro-content {
    background: rgba(255, 255, 255, 0.03);
  }

  .micro-item {
    font-size: 0.75rem;
    color: var(--text-secondary);
    white-space: nowrap;
  }

  .micro-item::before {
    content: " • ";
    color: var(--text-muted);
  }

  .micro-value {
    color: #3b82f6;
  }

  @media (max-width: 640px) {
    .card-row {
      flex-direction: column;
    }

    .card-right {
      flex: none;
      border-left: none;
      border-top: 1px solid rgba(255, 255, 255, 0.12);
    }

    :root.dark .card-right {
      border-color: rgba(255, 255, 255, 0.06);
    }
  }
</style>
