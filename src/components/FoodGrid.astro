---
import { foods, sortOptions } from "../data/foods";
import FoodCard from "./FoodCard.astro";

const currentSort = Astro.url.searchParams.get("sort") || "protein-desc";
let filtered = [...foods];

filtered.sort((a, b) => {
  let valA, valB;
  let isAscending = false;

  switch (currentSort) {
    case "protein-desc":
      valA = a.protein;
      valB = b.protein;
      isAscending = false;
      break;
    case "protein-asc":
      valA = a.protein;
      valB = b.protein;
      isAscending = true;
      break;
    case "calories-desc":
      valA = a.calories;
      valB = b.calories;
      isAscending = false;
      break;
    case "calories-asc":
      valA = a.calories;
      valB = b.calories;
      isAscending = true;
      break;
    case "protein-per-price": {
      const getVal = (f: {
        protein: number;
        price: number;
        priceUnit: string;
      }) => {
        const priceValue =
          f.priceUnit === "lb" ? (f.price / 453.6) * 100 : f.price;
        return f.protein / (priceValue || 1);
      };
      valA = getVal(a);
      valB = getVal(b);
      isAscending = false;
      break;
    }
    default:
      valA = a.protein;
      valB = b.protein;
      isAscending = false;
  }

  if (valA !== valB) {
    if (typeof valA === "number" && typeof valB === "number") {
      return isAscending ? valA - valB : valB - valA;
    }
    return isAscending
      ? String(valA).localeCompare(String(valB))
      : String(valB).localeCompare(String(valA));
  }

  // Fallback to name ascending (A-Z) on tie
  return a.name.localeCompare(b.name);
});
---

<section id="foods" class="food-grid-section">
  <div class="container">
    <div class="filters glass fade-in">
      <div class="filter-row">
        <div class="filter-group">
          <div class="search-wrapper">
            <input
              id="search-input"
              type="text"
              class="search-input"
              placeholder="Search foods..."
              data-i18n="foodgrid.searchPlaceholder"
            />
            <button
              class="search-clear"
              id="search-clear"
              aria-label="Clear search">&times;</button
            >
          </div>
        </div>
        <div class="filter-group desktop-sort-group">
          <label class="filter-label" data-i18n="foodgrid.sortBy">Sort By</label
          >
          <div class="filter-chips">
            {
              sortOptions.map((opt) => {
                const i18nKey = {
                  "protein-desc": "sort.highestProtein",
                  "protein-asc": "sort.lowestProtein",
                  "calories-desc": "sort.highestCalories",
                  "calories-asc": "sort.lowestCalories",
                  "protein-per-price": "sort.bestProteinPerPrice",
                }[opt.id];
                return (
                  <a
                    href={`?sort=${opt.id}`}
                    class={`chip ${currentSort === opt.id ? "active" : ""}`}
                    data-i18n={i18nKey}
                  >
                    {opt.label}
                  </a>
                );
              })
            }
          </div>
        </div>

        <div class="mobile-filter-dropdowns">
          <!-- Sort Dropdown -->
          <div class="custom-dropdown" id="sortDropdownContainer">
            <button
              class="dropdown-trigger"
              id="sortDropdownTrigger"
              aria-haspopup="listbox"
              aria-expanded="false"
            >
              <span id="sortTriggerText" data-i18n="sort.highestProtein"
                >Highest Protein</span
              >
              <svg
                class="chevron-icon"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"><path d="m6 9 6 6 6-6"></path></svg
              >
            </button>
            <div class="dropdown-menu" role="listbox">
              {
                sortOptions.map((opt) => {
                  const i18nKey = {
                    "protein-desc": "sort.highestProtein",
                    "protein-asc": "sort.lowestProtein",
                    "calories-desc": "sort.highestCalories",
                    "calories-asc": "sort.lowestCalories",
                    "protein-per-price": "sort.bestProteinPerPrice",
                  }[opt.id];
                  return (
                    <button
                      class="dropdown-item"
                      role="option"
                      data-value={opt.id}
                      data-i18n={i18nKey}
                    >
                      {opt.label}
                    </button>
                  );
                })
              }
            </div>
          </div>

          <!-- Category Dropdown -->
          <div class="custom-dropdown" id="categoryDropdownContainer">
            <button
              class="dropdown-trigger"
              id="categoryDropdownTrigger"
              aria-haspopup="listbox"
              aria-expanded="false"
            >
              <span id="categoryTriggerText" data-i18n="nav.allFoods"
                >All Foods</span
              >
              <svg
                class="chevron-icon"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"><path d="m6 9 6 6 6-6"></path></svg
              >
            </button>
            <div class="dropdown-menu" role="listbox">
              <button
                class="dropdown-item"
                role="option"
                data-value="all"
                data-i18n="nav.allFoods">All Foods</button
              >
              <button
                class="dropdown-item"
                role="option"
                data-value="meat"
                data-i18n="categories.meat">Meat & Poultry</button
              >
              <button
                class="dropdown-item"
                role="option"
                data-value="seafood"
                data-i18n="categories.seafood">Fish & Seafood</button
              >
              <button
                class="dropdown-item"
                role="option"
                data-value="dairy"
                data-i18n="categories.dairy">Dairy & Eggs</button
              >
              <button
                class="dropdown-item"
                role="option"
                data-value="plant"
                data-i18n="categories.plant">Plant-Based</button
              >
              <button
                class="dropdown-item"
                role="option"
                data-value="supplements"
                data-i18n="categories.supplements">Supplements</button
              >
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="grid">
      {filtered.map((food, i) => <FoodCard food={food} index={i} />)}
    </div>
    <div class="empty-state glass fade-in" style="display: none;">
      <svg
        width="48"
        height="48"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <circle cx="11" cy="11" r="8"></circle>
        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        <line x1="8" y1="11" x2="14" y2="11"></line>
      </svg>
      <h3 data-i18n="foodgrid.empty.title">No foods found</h3>
      <p data-i18n="foodgrid.empty.desc">
        Try adjusting your search or filters
      </p>
      <a href="/" class="btn" data-i18n="foodgrid.clearFilters">
        Clear all filters
      </a>
    </div>
  </div>
</section>

<script>
  function getQueryParam(name: string) {
    const params = new URLSearchParams(window.location.search);
    return params.get(name);
  }

  function applyClientSort(sortId: string) {
    const grid = document.querySelector(".grid");
    if (!grid) return;

    const cards = Array.from(
      grid.querySelectorAll(".food-card"),
    ) as HTMLElement[];
    if (cards.length === 0) return;

    let isAscending = false;
    let dataAttr = "protein";

    switch (sortId) {
      case "protein-desc":
        dataAttr = "protein";
        isAscending = false;
        break;
      case "protein-asc":
        dataAttr = "protein";
        isAscending = true;
        break;
      case "calories-desc":
        dataAttr = "calories";
        isAscending = false;
        break;
      case "calories-asc":
        dataAttr = "calories";
        isAscending = true;
        break;
      case "protein-per-price":
        dataAttr = "protein-per-price";
        isAscending = false;
        break;
      default:
        dataAttr = "protein";
        isAscending = false;
    }

    cards.sort((a, b) => {
      const valA = parseFloat(a.getAttribute(`data-${dataAttr}`) || "0");
      const valB = parseFloat(b.getAttribute(`data-${dataAttr}`) || "0");

      if (valA !== valB) {
        return isAscending ? valA - valB : valB - valA;
      }

      const nameA = a.getAttribute("data-name") || "";
      const nameB = b.getAttribute("data-name") || "";
      return nameA.localeCompare(nameB);
    });
    let visibleIndex = 0;
    cards.forEach((card) => {
      if (!card.classList.contains("filtered-out")) {
        card.style.animationDelay = `${visibleIndex * 50}ms`;
        visibleIndex++;
      }
      grid.appendChild(card);
    });
  }

  let searchQuery = "";
  function applySearch(query: string) {
    searchQuery = query.toLowerCase().trim();
    applyFilters();
  }

  function applyFilters() {
    const windowHash = window.location.hash.slice(1);
    const validCategories = [
      "meat",
      "seafood",
      "dairy",
      "plant",
      "supplements",
    ];
    const activeCategory = validCategories.includes(windowHash)
      ? windowHash
      : null;

    const cards = document.querySelectorAll(
      ".food-card",
    ) as NodeListOf<HTMLElement>;
    let visibleIndex = 0;
    cards.forEach((card) => {
      const name = card.getAttribute("data-name") || "";
      const category = card.getAttribute("data-category") || "";
      const matchesSearch = !searchQuery || name.includes(searchQuery);

      const matchesCategory = !activeCategory || category === activeCategory;

      if (matchesSearch && matchesCategory) {
        card.classList.remove("filtered-out");
        card.style.animationDelay = `${visibleIndex * 50}ms`;
        card.style.animation = "none";
        card.offsetHeight;
        card.style.animation = "";
        visibleIndex++;
      } else {
        card.classList.add("filtered-out");
      }
    });
    const emptyState = document.querySelector(".empty-state") as HTMLElement;
    if (emptyState) {
      emptyState.style.display = visibleIndex === 0 ? "flex" : "none";
    }
  }

  function applyClientFilter(_categoryId: string | null) {
    applyFilters();
  }

  function updateHeaderActiveState(hash: string) {
    const cleanHash = hash.replace("#", "");
    const validCategories = [
      "meat",
      "seafood",
      "dairy",
      "plant",
      "supplements",
    ];
    const hasValidCategory = validCategories.includes(cleanHash);

    const desktopLinks = document.querySelectorAll(".nav-desktop .nav-link");
    desktopLinks.forEach((link) => {
      const href = link.getAttribute("href");
      if (href === "/" && (!cleanHash || cleanHash === "features")) {
        link.classList.add("active");
      } else if (hasValidCategory && href === `#${cleanHash}`) {
        link.classList.add("active");
      } else if (cleanHash === "foods" && href === "#foods") {
        link.classList.add("active");
      } else {
        link.classList.remove("active");
      }
    });

    const mobileLinks = document.querySelectorAll(".mobile-nav .mobile-link");
    mobileLinks.forEach((link) => {
      const href = link.getAttribute("href");
      if (href === "/" && (!cleanHash || cleanHash === "features")) {
        link.classList.add("active");
      } else if (hasValidCategory && href === `#${cleanHash}`) {
        link.classList.add("active");
      } else if (cleanHash === "foods" && href === "#foods") {
        link.classList.add("active");
      } else {
        link.classList.remove("active");
      }
    });
  }

  document.querySelectorAll(".chip").forEach((chip) => {
    chip.addEventListener(
      "click",
      function (this: HTMLAnchorElement, e: Event) {
        e.preventDefault();

        const href = this.getAttribute("href") || "";
        const params = new URLSearchParams(href.split("?")[1] || "");
        const sortId = params.get("sort") || "protein-desc";

        const parent = this.closest(".filter-chips")!;
        parent
          .querySelectorAll(".chip")
          .forEach((c) => c.classList.remove("active"));
        this.classList.add("active");

        applyClientSort(sortId);
        updateSortDropdownState(sortId);

        const url = new URL(window.location.href);
        url.searchParams.set("sort", sortId);
        window.history.pushState({}, "", url.toString());
      },
    );
  });

  const searchInput = document.getElementById(
    "search-input",
  ) as HTMLInputElement;
  if (searchInput) {
    let debounceTimer: ReturnType<typeof setTimeout>;
    searchInput.addEventListener("input", function () {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(() => applySearch(this.value), 100);
    });
  }
  const clearBtn = document.getElementById("search-clear") as HTMLButtonElement;
  if (clearBtn && searchInput) {
    clearBtn.addEventListener("click", function () {
      searchInput.value = "";
      applySearch("");
      searchInput.focus();
    });
  }

  document
    .querySelectorAll(".nav-desktop .nav-link, .mobile-nav .mobile-link")
    .forEach((link) => {
      link.addEventListener(
        "click",
        function (this: HTMLAnchorElement, e: Event) {
          const href = this.getAttribute("href");
          if (href && href.startsWith("#")) {
            e.preventDefault();
            const hashPart = href.slice(1);
            window.location.hash = hashPart;
          }
        },
      );
    });

  document.querySelectorAll("[data-sort]").forEach((link) => {
    link.addEventListener(
      "click",
      function (this: HTMLAnchorElement, e: Event) {
        e.preventDefault();
        const sortId = this.getAttribute("data-sort");
        if (!sortId) return;

        const url = new URL(window.location.href);
        url.searchParams.set("sort", sortId);
        window.history.pushState({}, "", url.toString());

        const chips = document.querySelectorAll(".chip");
        chips.forEach((chip) => {
          const href = chip.getAttribute("href") || "";
          const params = new URLSearchParams(href.split("?")[1] || "");
          const chipSortId = params.get("sort");
          if (chipSortId === sortId) {
            const parent = chip.closest(".filter-chips")!;
            parent
              .querySelectorAll(".chip")
              .forEach((c) => c.classList.remove("active"));
            chip.classList.add("active");
          }
        });

        applyClientSort(sortId);
        updateSortDropdownState(sortId);

        const gridSection = document.getElementById("foods");
        gridSection?.scrollIntoView({ behavior: "smooth" });
      },
    );
  });

  function updateCategoryDropdownState(hash: string) {
    const categoryDropdown = document.getElementById(
      "categoryDropdownContainer",
    );
    if (!categoryDropdown) return;

    const value = hash || "all";
    const items = categoryDropdown.querySelectorAll(".dropdown-item");
    let activeItem = null;

    items.forEach((item) => {
      const itemVal = item.getAttribute("data-value");
      if (itemVal === value) {
        item.classList.add("active");
        activeItem = item;
      } else {
        item.classList.remove("active");
      }
    });

    if (activeItem) {
      const triggerText = document.getElementById("categoryTriggerText");
      if (triggerText) {
        const i18nKey = activeItem.getAttribute("data-i18n");
        if (i18nKey) {
          triggerText.setAttribute("data-i18n", i18nKey);
          if (window.__applyLanguage) {
            window.__applyLanguage(
              document.documentElement.getAttribute("lang") || "en",
            );
          }
        }
      }
    }
  }

  function updateSortDropdownState(sortId: string) {
    const sortDropdown = document.getElementById("sortDropdownContainer");
    if (!sortDropdown) return;

    const activeSort = sortId || "protein-desc";
    const items = sortDropdown.querySelectorAll(".dropdown-item");
    let activeItem = null;

    items.forEach((item) => {
      const itemVal = item.getAttribute("data-value");
      if (itemVal === activeSort) {
        item.classList.add("active");
        activeItem = item;
      } else {
        item.classList.remove("active");
      }
    });

    if (activeItem) {
      const triggerText = document.getElementById("sortTriggerText");
      if (triggerText) {
        const i18nKey = activeItem.getAttribute("data-i18n");
        if (i18nKey) {
          triggerText.setAttribute("data-i18n", i18nKey);
          if (window.__applyLanguage) {
            window.__applyLanguage(
              document.documentElement.getAttribute("lang") || "en",
            );
          }
        }
      }
    }
  }

  function initDropdowns() {
    const sortDropdown = document.getElementById("sortDropdownContainer");
    const categoryDropdown = document.getElementById(
      "categoryDropdownContainer",
    );

    if (sortDropdown && categoryDropdown) {
      const sortTrigger = sortDropdown.querySelector(".dropdown-trigger");
      const categoryTrigger =
        categoryDropdown.querySelector(".dropdown-trigger");

      if (sortTrigger && categoryTrigger) {
        sortTrigger.addEventListener("click", (e) => {
          e.stopPropagation();
          sortDropdown.classList.toggle("open");
          categoryDropdown.classList.remove("open");
        });

        categoryTrigger.addEventListener("click", (e) => {
          e.stopPropagation();
          categoryDropdown.classList.toggle("open");
          sortDropdown.classList.remove("open");
        });
      }

      sortDropdown.querySelectorAll(".dropdown-item").forEach((item) => {
        item.addEventListener("click", function () {
          const sortId = this.getAttribute("data-value");
          if (!sortId) return;

          applyClientSort(sortId);

          const url = new URL(window.location.href);
          url.searchParams.set("sort", sortId);
          window.history.pushState({}, "", url.toString());

          const chips = document.querySelectorAll(".chip");
          chips.forEach((chip) => {
            const href = chip.getAttribute("href") || "";
            const params = new URLSearchParams(href.split("?")[1] || "");
            const chipSortId = params.get("sort");
            if (chipSortId === sortId) {
              const parent = chip.closest(".filter-chips")!;
              parent
                .querySelectorAll(".chip")
                .forEach((c) => c.classList.remove("active"));
              chip.classList.add("active");
            }
          });

          updateSortDropdownState(sortId);
        });
      });

      categoryDropdown.querySelectorAll(".dropdown-item").forEach((item) => {
        item.addEventListener("click", function () {
          const catValue = this.getAttribute("data-value");
          if (!catValue) return;

          window.location.hash = catValue === "all" ? "" : catValue;
        });
      });

      document.addEventListener("click", () => {
        sortDropdown.classList.remove("open");
        categoryDropdown.classList.remove("open");
      });
    }
  }

  window.addEventListener("hashchange", () => {
    const hash = window.location.hash.slice(1);
    applyClientFilter(hash);
    updateHeaderActiveState(hash);
    updateCategoryDropdownState(hash);

    const validCategories = [
      "meat",
      "seafood",
      "dairy",
      "plant",
      "supplements",
    ];
    if (validCategories.includes(hash) || hash === "foods") {
      const gridSection = document.getElementById("foods");
      gridSection?.scrollIntoView({ behavior: "smooth" });
    }
  });

  const runInit = () => {
    initDropdowns();

    const initialSort = getQueryParam("sort") || "protein-desc";
    applyClientSort(initialSort);
    updateSortDropdownState(initialSort);

    const chips = document.querySelectorAll(".chip");
    chips.forEach((chip) => {
      const href = chip.getAttribute("href") || "";
      const params = new URLSearchParams(href.split("?")[1] || "");
      const sortId = params.get("sort");
      if (sortId === initialSort) {
        const parent = chip.closest(".filter-chips")!;
        parent
          .querySelectorAll(".chip")
          .forEach((c) => c.classList.remove("active"));
        chip.classList.add("active");
      }
    });

    const hash = window.location.hash.slice(1);
    applyClientFilter(hash);
    updateHeaderActiveState(hash);
    updateCategoryDropdownState(hash);

    if (hash) {
      setTimeout(() => {
        const gridSection = document.getElementById("foods");
        gridSection?.scrollIntoView({ behavior: "smooth" });
      }, 100);
    }
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", runInit);
  } else {
    runInit();
  }
</script>

<style>
  .food-grid-section {
    padding: 6rem 0 2rem;
    scroll-margin-top: 80px;
  }

  .filters {
    position: relative;
    z-index: 2;
    padding: 1.25rem;
    margin-bottom: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .filter-group {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .filter-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-muted);
    font-weight: 600;
    flex-shrink: 0;
  }

  .filter-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .chip {
    padding: 0.375rem 0.75rem;
    border-radius: 0.375rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--text-secondary);
    background: rgba(0, 0, 0, 0.03);
    border: 1px solid rgba(0, 0, 0, 0.06);
    cursor: pointer;
    transition: all 0.2s;
    white-space: nowrap;
    text-decoration: none;
  }

  .chip:hover {
    background: rgba(0, 0, 0, 0.06);
    color: var(--text-primary);
  }

  :root.dark .chip {
    background: rgba(255, 255, 255, 0.04);
    border-color: rgba(255, 255, 255, 0.06);
  }

  :root.dark .chip:hover {
    background: rgba(255, 255, 255, 0.08);
  }

  .search-input {
    width: 100%;
    padding: 0.5rem 0.75rem;
    border-radius: 0.375rem;
    border: 1px solid rgba(0, 0, 0, 0.12);
    background: rgba(255, 255, 255, 0.6);
    font-size: 0.875rem;
    color: var(--text-primary);
    outline: none;
    transition:
      border-color 0.2s,
      box-shadow 0.2s;
    padding-right: 2rem;
  }

  .search-wrapper {
    position: relative;
    width: 100%;
  }

  .search-clear {
    position: absolute;
    right: 0.375rem;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    font-size: 1.25rem;
    cursor: pointer;
    color: var(--text-muted);
    padding: 0 0.25rem;
    line-height: 1;
    display: none;
    align-items: center;
    justify-content: center;
  }

  .search-clear:hover {
    color: var(--text-primary);
  }

  .search-input:not(:placeholder-shown) ~ .search-clear {
    display: flex;
  }

  :root.dark .search-input {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.1);
    color: var(--text-primary);
  }

  .search-input:focus {
    border-color: var(--accent-green);
    box-shadow: 0 0 0 2px rgba(34, 197, 94, 0.2);
  }

  :root.dark .search-input:focus {
    border-color: var(--accent-green);
    box-shadow: 0 0 0 2px rgba(34, 197, 94, 0.15);
  }

  .search-input::placeholder {
    color: var(--text-muted);
  }

  .chip.active {
    background: rgba(34, 197, 94, 0.15);
    border-color: var(--accent-green);
    color: var(--accent-green);
  }

  .filter-row {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    justify-content: space-between;
  }

  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  /* .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 20px;
    padding: 20px;
  } */

  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 4rem 2rem;
    text-align: center;
    gap: 0.75rem;
  }

  .empty-state svg {
    color: var(--text-muted);
    opacity: 0.5;
  }

  .empty-state h3 {
    margin: 0;
    font-size: 1.25rem;
  }

  .empty-state p {
    margin: 0;
    color: var(--text-muted);
