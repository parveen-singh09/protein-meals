---
import { foods, categories, sortOptions, getSortValue, availabilityOptions } from '../data/foods';
import FoodCard from './FoodCard.astro';

const currentSort = Astro.url.searchParams.get('sort') || 'protein-desc';
const currentCategory = Astro.url.searchParams.get('category') || 'all';
const currentAvailability = Astro.url.searchParams.get('availability') || 'all';
const currentSearch = Astro.url.searchParams.get('search') || '';

let filtered = [...foods];

if (currentCategory !== 'all') {
  filtered = filtered.filter(f => f.category === currentCategory);
}

if (currentAvailability !== 'all') {
  filtered = filtered.filter(f => f.availability === currentAvailability);
}

if (currentSearch) {
  const q = currentSearch.toLowerCase();
  filtered = filtered.filter(f =>
    f.name.toLowerCase().includes(q) ||
    f.description.toLowerCase().includes(q) ||
    f.tags.some(t => t.toLowerCase().includes(q))
  );
}

filtered.sort((a, b) => {
  const va = getSortValue(a, currentSort);
  const vb = getSortValue(b, currentSort);
  if (typeof va === 'number' && typeof vb === 'number') return vb - va;
  return String(va).localeCompare(String(vb));
});
---

<section id="foods" class="food-grid-section">
  <div class="container">
    <div class="section-header fade-in">
      <h2>Browse All Foods</h2>
      <p class="section-subtitle">{filtered.length} of {foods.length} protein-rich foods found</p>
    </div>

    <div class="filters glass fade-in">
      <div class="search-wrapper">
        <svg class="search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        <input
          type="search"
          class="search-input"
          placeholder="Search foods..."
          value={currentSearch}
          oninput="handleSearch(this.value)"
        />
      </div>

      <div class="filter-group">
        <label class="filter-label">Category</label>
        <div class="filter-chips">
          {categories.map(cat => (
            <a
              href={`?category=${cat.id}&sort=${currentSort}&availability=${currentAvailability}&search=${currentSearch}`}
              class={`chip ${currentCategory === cat.id ? 'active' : ''}`}
            >{cat.label}</a>
          ))}
        </div>
      </div>

      <div class="filter-row">
        <div class="filter-group">
          <label class="filter-label">Sort By</label>
          <div class="filter-chips">
            {sortOptions.map(opt => (
              <a
                href={`?sort=${opt.id}&category=${currentCategory}&availability=${currentAvailability}&search=${currentSearch}`}
                class={`chip ${currentSort === opt.id ? 'active' : ''}`}
              >{opt.label}</a>
            ))}
          </div>
        </div>

        <div class="filter-group">
          <label class="filter-label">Availability</label>
          <div class="filter-chips">
            {availabilityOptions.map(av => (
              <a
                href={`?availability=${av.id}&sort=${currentSort}&category=${currentCategory}&search=${currentSearch}`}
                class={`chip ${currentAvailability === av.id ? 'active' : ''}`}
              >{av.label}</a>
            ))}
          </div>
        </div>
      </div>
    </div>

    {filtered.length > 0 ? (
      <div class="grid">
        {filtered.map((food, i) => <FoodCard food={food} index={i} />)}
      </div>
    ) : (
      <div class="empty-state glass fade-in">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
          <line x1="8" y1="11" x2="14" y2="11"/>
        </svg>
        <h3>No foods found</h3>
        <p>Try adjusting your search or filters</p>
        <a href="/" class="btn">Clear all filters</a>
      </div>
    )}
  </div>
</section>

<script>
  let searchTimeout;

  window.handleSearch = function(value) {
    clearTimeout(searchTimeout);
    searchTimeout = setTimeout(() => {
      const url = new URL(window.location.href);
      url.searchParams.set('search', value);
      if (!value) url.searchParams.delete('search');
      window.location.href = url.toString();
    }, 400);
  };

  document.querySelectorAll('.chip').forEach(chip => {
    chip.addEventListener('click', function(e) {
      const parent = this.closest('.filter-chips');
      parent.querySelectorAll('.chip').forEach(c => c.classList.remove('active'));
      this.classList.add('active');
    });
  });
</script>

<style>
  .food-grid-section {
    padding: 6rem 0 2rem;
    scroll-margin-top: 80px;
  }

  .section-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .section-header h2 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    margin: 0 0 0.5rem;
    background: linear-gradient(135deg, var(--accent-green), var(--accent-teal), var(--accent-lime));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .section-subtitle {
    color: var(--text-muted);
    font-size: 0.9375rem;
    margin: 0;
  }

  .filters {
    padding: 1.25rem;
    margin-bottom: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .search-wrapper {
    position: relative;
  }

  .search-icon {
    position: absolute;
    left: 0.875rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-muted);
    pointer-events: none;
  }

  .search-input {
    width: 100%;
    padding: 0.75rem 1rem 0.75rem 2.75rem;
    border-radius: 0.5rem;
    border: 1px solid rgba(0, 0, 0, 0.08);
    background: rgba(0, 0, 0, 0.02);
    color: var(--text-primary);
    font-size: 0.875rem;
    font-family: var(--font-sans);
    outline: none;
    transition: border-color 0.2s;
  }

  .search-input::placeholder {
    color: var(--text-muted);
  }

  .search-input:focus {
    border-color: var(--accent-green);
    box-shadow: 0 0 0 2px rgba(34, 197, 94, 0.15);
  }

  :root.dark .search-input {
    border-color: rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.04);
  }

  .filter-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .filter-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-muted);
    font-weight: 600;
  }

  .filter-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .chip {
    padding: 0.375rem 0.75rem;
    border-radius: 0.375rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--text-secondary);
    background: rgba(0, 0, 0, 0.03);
    border: 1px solid rgba(0, 0, 0, 0.06);
    cursor: pointer;
    transition: all 0.2s;
    white-space: nowrap;
    text-decoration: none;
  }

  .chip:hover {
    background: rgba(0, 0, 0, 0.06);
    color: var(--text-primary);
  }

  :root.dark .chip {
    background: rgba(255, 255, 255, 0.04);
    border-color: rgba(255, 255, 255, 0.06);
  }

  :root.dark .chip:hover {
    background: rgba(255, 255, 255, 0.08);
  }

  .chip.active {
    background: rgba(34, 197, 94, 0.15);
    border-color: var(--accent-green);
    color: var(--accent-green);
  }

  .filter-row {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 4rem 2rem;
    text-align: center;
    gap: 0.75rem;
  }

  .empty-state svg {
    color: var(--text-muted);
    opacity: 0.5;
  }

  .empty-state h3 {
    margin: 0;
    font-size: 1.25rem;
  }

  .empty-state p {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.875rem;
  }

  @media (min-width: 480px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 768px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .filter-row {
      flex-direction: row;
      gap: 2rem;
    }
    .filter-row .filter-group {
      flex: 1;
    }
  }

  @media (min-width: 1024px) {
    .grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 1280px) {
    .grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
</style>
