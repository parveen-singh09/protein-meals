---
import { foods, sortOptions } from "../data/foods";
import FoodCard from "./FoodCard.astro";

const currentSort = Astro.url.searchParams.get("sort") || "protein-desc";
let filtered = [...foods];

filtered.sort((a, b) => {
  let valA, valB;
  let isAscending = false;

  switch (currentSort) {
    case "protein-desc":
      valA = a.protein;
      valB = b.protein;
      isAscending = false;
      break;
    case "protein-asc":
      valA = a.protein;
      valB = b.protein;
      isAscending = true;
      break;
    case "calories-desc":
      valA = a.calories;
      valB = b.calories;
      isAscending = false;
      break;
    case "calories-asc":
      valA = a.calories;
      valB = b.calories;
      isAscending = true;
      break;
    case "protein-per-price": {
      const getVal = (f: { protein: number; price: number; priceUnit: string }) => {
        const priceValue =
          f.priceUnit === "lb" ? (f.price / 453.6) * 100 : f.price;
        return f.protein / (priceValue || 1);
      };
      valA = getVal(a);
      valB = getVal(b);
      isAscending = false;
      break;
    }
    default:
      valA = a.protein;
      valB = b.protein;
      isAscending = false;
  }

  if (valA !== valB) {
    if (typeof valA === "number" && typeof valB === "number") {
      return isAscending ? valA - valB : valB - valA;
    }
    return isAscending
      ? String(valA).localeCompare(String(valB))
      : String(valB).localeCompare(String(valA));
  }

  // Fallback to name ascending (A-Z) on tie
  return a.name.localeCompare(b.name);
});
---

<section id="foods" class="food-grid-section">
  <div class="container">
    <div class="section-header fade-in">
      <h2>Browse All Foods</h2>
    </div>

    <div class="filters glass fade-in">
      <div class="filter-row">
        <div class="filter-group">
          <label class="filter-label">Sort By</label>
          <div class="filter-chips">
            {
              sortOptions.map((opt) => (
                <a
                  href={`?sort=${opt.id}`}
                  class={`chip ${currentSort === opt.id ? "active" : ""}`}
                >
                  {opt.label}
                </a>
              ))
            }
          </div>
        </div>
      </div>
    </div>

    <div class="grid">
      {filtered.map((food, i) => (
        <FoodCard food={food} index={i} />
      ))}
    </div>
    <div class="empty-state glass fade-in" style="display: none;">
      <svg
        width="48"
        height="48"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <circle cx="11" cy="11" r="8" />
        <line x1="21" y1="21" x2="16.65" y2="16.65" />
        <line x1="8" y1="11" x2="14" y2="11" />
      </svg>
      <h3>No foods found</h3>
      <p>Try adjusting your search or filters</p>
      <a href="/" class="btn">
        Clear all filters
      </a>
    </div>
  </div>
</section>

<script>
  function getQueryParam(name: string) {
    const params = new URLSearchParams(window.location.search);
    return params.get(name);
  }

  function applyClientSort(sortId: string) {
    const grid = document.querySelector(".grid");
    if (!grid) return;

    const cards = Array.from(
      grid.querySelectorAll(".food-card"),
    ) as HTMLElement[];
    if (cards.length === 0) return;

    let isAscending = false;
    let dataAttr = "protein";

    switch (sortId) {
      case "protein-desc":
        dataAttr = "protein";
        isAscending = false;
        break;
      case "protein-asc":
        dataAttr = "protein";
        isAscending = true;
        break;
      case "calories-desc":
        dataAttr = "calories";
        isAscending = false;
        break;
      case "calories-asc":
        dataAttr = "calories";
        isAscending = true;
        break;
      case "protein-per-price":
        dataAttr = "protein-per-price";
        isAscending = false;
        break;
      default:
        dataAttr = "protein";
        isAscending = false;
    }

    cards.sort((a, b) => {
      const valA = parseFloat(a.getAttribute(`data-${dataAttr}`) || "0");
      const valB = parseFloat(b.getAttribute(`data-${dataAttr}`) || "0");

      if (valA !== valB) {
        return isAscending ? valA - valB : valB - valA;
      }

      // Tie breaker: Name A-Z
      const nameA = a.getAttribute("data-name") || "";
      const nameB = b.getAttribute("data-name") || "";
      return nameA.localeCompare(nameB);
    });

    // Re-append cards in the sorted order and update animation delays for visible ones
    let visibleIndex = 0;
    cards.forEach((card) => {
      if (!card.classList.contains("filtered-out")) {
        card.style.animationDelay = `${visibleIndex * 50}ms`;
        visibleIndex++;
      }
      grid.appendChild(card);
    });
  }

  function applyClientFilter(categoryId: string | null) {
    const grid = document.querySelector(".grid");
    if (!grid) return;

    const cards = Array.from(
      grid.querySelectorAll(".food-card"),
    ) as HTMLElement[];
    if (cards.length === 0) return;

    const validCategories = ["meat", "seafood", "dairy", "plant", "supplements"];
    const hasCategory = categoryId && validCategories.includes(categoryId);

    let visibleIndex = 0;
    cards.forEach((card) => {
      const cardCategory = card.getAttribute("data-category");
      if (!hasCategory || cardCategory === categoryId) {
        card.classList.remove("filtered-out");
        card.style.animationDelay = `${visibleIndex * 50}ms`;
        
        // Reset and retrigger animation for smooth entry
        card.style.animation = "none";
        card.offsetHeight; // trigger reflow
        card.style.animation = "";
        
        visibleIndex++;
      } else {
        card.classList.add("filtered-out");
      }
    });

    const emptyState = document.querySelector(".empty-state") as HTMLElement;
    if (emptyState) {
      emptyState.style.display = visibleIndex === 0 ? "flex" : "none";
    }
  }

  function updateHeaderActiveState(hash: string) {
    const cleanHash = hash.replace("#", "");
    const validCategories = ["meat", "seafood", "dairy", "plant", "supplements"];
    const hasValidCategory = validCategories.includes(cleanHash);
    
    // Desktop links
    const desktopLinks = document.querySelectorAll(".nav-desktop .nav-link");
    desktopLinks.forEach(link => {
      const href = link.getAttribute("href");
      if (href === "/" && (!cleanHash || cleanHash === "features")) {
        link.classList.add("active");
      } else if (hasValidCategory && href === `#${cleanHash}`) {
        link.classList.add("active");
      } else if (cleanHash === "foods" && href === "#foods") {
        link.classList.add("active");
      } else {
        link.classList.remove("active");
      }
    });

    // Mobile links
    const mobileLinks = document.querySelectorAll(".mobile-nav .mobile-link");
    mobileLinks.forEach(link => {
      const href = link.getAttribute("href");
      if (href === "/" && (!cleanHash || cleanHash === "features")) {
        link.classList.add("active");
      } else if (hasValidCategory && href === `#${cleanHash}`) {
        link.classList.add("active");
      } else if (cleanHash === "foods" && href === "#foods") {
        link.classList.add("active");
      } else {
        link.classList.remove("active");
      }
    });
  }

  // Bind click events on chips
  document.querySelectorAll(".chip").forEach((chip) => {
    chip.addEventListener(
      "click",
      function (this: HTMLAnchorElement, e: Event) {
        e.preventDefault();

        const href = this.getAttribute("href") || "";
        const params = new URLSearchParams(href.split("?")[1] || "");
        const sortId = params.get("sort") || "protein-desc";

        // Update active chip styling
        const parent = this.closest(".filter-chips")!;
        parent
          .querySelectorAll(".chip")
          .forEach((c) => c.classList.remove("active"));
        this.classList.add("active");

        // Apply sort
        applyClientSort(sortId);

        // Update URL query parameters without reloading
        const url = new URL(window.location.href);
        url.searchParams.set("sort", sortId);
        window.history.pushState({}, "", url.toString());
      },
    );
  });

  // Bind click events on header and mobile navigation category links starting with #
  document.querySelectorAll(".nav-desktop .nav-link, .mobile-nav .mobile-link").forEach((link) => {
    link.addEventListener("click", function (this: HTMLAnchorElement, e: Event) {
      const href = this.getAttribute("href");
      if (href && href.startsWith("#")) {
        e.preventDefault();
        const hashPart = href.slice(1);
        window.location.hash = hashPart;
      }
    });
  });

  // Bind click events on footer sort links
  document.querySelectorAll("[data-sort]").forEach(link => {
    link.addEventListener("click", function(this: HTMLAnchorElement, e: Event) {
      e.preventDefault();
      const sortId = this.getAttribute("data-sort");
      if (!sortId) return;

      // Update URL query parameter without reloading
      const url = new URL(window.location.href);
      url.searchParams.set("sort", sortId);
      window.history.pushState({}, "", url.toString());

      // Update active chip styling in the grid filters
      const chips = document.querySelectorAll(".chip");
      chips.forEach(chip => {
        const href = chip.getAttribute("href") || "";
        const params = new URLSearchParams(href.split("?")[1] || "");
        const chipSortId = params.get("sort");
        if (chipSortId === sortId) {
          const parent = chip.closest(".filter-chips")!;
          parent.querySelectorAll(".chip").forEach(c => c.classList.remove("active"));
          chip.classList.add("active");
        }
      });

      // Apply sorting
      applyClientSort(sortId);

      // Smooth scroll to grid section
      const gridSection = document.getElementById("foods");
      gridSection?.scrollIntoView({ behavior: "smooth" });
    });
  });

  // Handle hash changes (category filters)
  window.addEventListener("hashchange", () => {
    const hash = window.location.hash.slice(1);
    applyClientFilter(hash);
    updateHeaderActiveState(hash);
    
    // Smooth scroll to the foods section only if the hash is a category or All Foods
    const validCategories = ["meat", "seafood", "dairy", "plant", "supplements"];
    if (validCategories.includes(hash) || hash === "foods") {
      const gridSection = document.getElementById("foods");
      gridSection?.scrollIntoView({ behavior: "smooth" });
    }
  });

  // Handle initial load sort if URL has a search param
  const runInit = () => {
    const initialSort = getQueryParam("sort");
    if (initialSort) {
      applyClientSort(initialSort);

      const chips = document.querySelectorAll(".chip");
      chips.forEach((chip) => {
        const href = chip.getAttribute("href") || "";
        const params = new URLSearchParams(href.split("?")[1] || "");
        const sortId = params.get("sort");
        if (sortId === initialSort) {
          const parent = chip.closest(".filter-chips")!;
          parent
            .querySelectorAll(".chip")
            .forEach((c) => c.classList.remove("active"));
          chip.classList.add("active");
        }
      });
    }

    const hash = window.location.hash.slice(1);
    applyClientFilter(hash);
    updateHeaderActiveState(hash);

    if (hash) {
      // Delay slightly for render completion
      setTimeout(() => {
        const gridSection = document.getElementById("foods");
        gridSection?.scrollIntoView({ behavior: "smooth" });
      }, 100);
    }
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", runInit);
  } else {
    runInit();
  }
</script>

<style>
  .food-grid-section {
    padding: 6rem 0 2rem;
    scroll-margin-top: 80px;
  }

  .section-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .section-header h2 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    margin: 0 0 0.5rem;
    background: linear-gradient(
      135deg,
      var(--accent-green),
      var(--accent-teal),
      var(--accent-lime)
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .filters {
    padding: 1.25rem;
    margin-bottom: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .filter-group {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .filter-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-muted);
    font-weight: 600;
    flex-shrink: 0;
  }

  .filter-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .chip {
    padding: 0.375rem 0.75rem;
    border-radius: 0.375rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--text-secondary);
    background: rgba(0, 0, 0, 0.03);
    border: 1px solid rgba(0, 0, 0, 0.06);
    cursor: pointer;
    transition: all 0.2s;
    white-space: nowrap;
    text-decoration: none;
  }

  .chip:hover {
    background: rgba(0, 0, 0, 0.06);
    color: var(--text-primary);
  }

  :root.dark .chip {
    background: rgba(255, 255, 255, 0.04);
    border-color: rgba(255, 255, 255, 0.06);
  }

  :root.dark .chip:hover {
    background: rgba(255, 255, 255, 0.08);
  }

  .chip.active {
    background: rgba(34, 197, 94, 0.15);
    border-color: var(--accent-green);
    color: var(--accent-green);
  }

  .filter-row {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 4rem 2rem;
    text-align: center;
    gap: 0.75rem;
  }

  .empty-state svg {
    color: var(--text-muted);
    opacity: 0.5;
  }

  .empty-state h3 {
    margin: 0;
    font-size: 1.25rem;
  }

  .empty-state p {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.875rem;
  }

  @media (min-width: 480px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 768px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .filter-row {
      flex-direction: row;
      gap: 2rem;
    }
    .filter-row .filter-group {
      flex: 1;
    }
  }

  @media (min-width: 1024px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1400px) {
    .grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  :global(.food-card.filtered-out) {
    display: none !important;
  }
</style>
