---

const features = [
  {
    icon: "nutrition",
    i18nTitle: "features.macros.title",
    i18nDesc: "features.macros.desc",
    defaultTitle: "Complete Macros & Micros",
    defaultDesc: "Protein, calories, carbs, fat, fiber, and 21 micronutrients per 100g for every food. No guesswork.",
  },
  {
    icon: "dollar",
    i18nTitle: "features.price.title",
    i18nDesc: "features.price.desc",
    defaultTitle: "Price Tracking",
    defaultDesc: "Average prices included so you can find the best protein-per-dollar value for your budget.",
  },
  {
    icon: "sort",
    i18nTitle: "features.sorting.title",
    i18nDesc: "features.sorting.desc",
    defaultTitle: "Smart Sorting",
    defaultDesc: "Sort by protein content, calories, protein per dollar, and more to find exactly what you need.",
  },
  {
    icon: "search",
    i18nTitle: "features.filter.title",
    i18nDesc: "features.filter.desc",
    defaultTitle: "Filter & Search",
    defaultDesc: "Filter by meat, seafood, dairy, plant-based, supplements, or search any food instantly.",
  },
];

function iconSvg(id: string) {
  switch (id) {
    case "nutrition":
      return `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 13.87A4 4 0 0 1 7.41 6a5.11 5.11 0 0 1 1.05-1.54 5 5 0 0 1 7.08 0A5.11 5.11 0 0 1 16.59 6 4 4 0 0 1 18 13.87V21H6Z"/><line x1="6" y1="17" x2="18" y2="17"/></svg>`;
    case "dollar":
      return `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>`;
    case "sort":
      return `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 3-3 3 3"/><path d="M6 6v12"/><path d="m21 15-3 3-3-3"/><path d="M18 18V6"/></svg>`;
    case "search":
      return `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>`;
  }
}
---

<section class="features fade-in-on-scroll">
  <div class="container">
    <div class="features-header">
      <span class="features-badge" data-i18n="features.label">Why Choose HighProtein Foodz</span>
      <h2 class="features-title" data-i18n="features.title">Everything You Need to Track Your Protein</h2>
    </div>
    <div class="features-grid">
      {
        features.map((f, i) => (
          <div class="feature-card glass fade-in-on-scroll" style={`animation-delay: ${i * 0.1}s`}>
            <div class="feature-icon" set:html={iconSvg(f.icon)} />
            <h3 class="feature-title" data-i18n={f.i18nTitle}>{f.defaultTitle}</h3>
            <p class="feature-desc" data-i18n={f.i18nDesc}>{f.defaultDesc}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .features {
    padding: 14rem 0;
    scroll-margin-top: 80px;
  }

  .features-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .features-badge {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--accent-green);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.75rem;
  }

  .features-title {
    font-size: clamp(1.5rem, 3.5vw, 2.25rem);
    font-weight: 800;
    margin: 0;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .feature-card {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .feature-icon {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.75rem;
    background: rgba(22, 163, 74, 0.1);
    color: var(--accent-green);
    flex-shrink: 0;
  }

  :root.dark .feature-icon {
    background: rgba(22, 163, 74, 0.15);
  }

  .feature-title {
    font-size: 1rem;
    font-weight: 700;
    margin: 0;
    letter-spacing: -0.01em;
  }

  .feature-desc {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 640px) {
    .features-grid {
      grid-template-columns: 1fr;
    }
    .features {
      padding: 5rem 0;
    }
  }

  @media (min-width: 768px) {
    .feature-card {
      padding: 2rem;
    }
  }

  @media (min-width: 1024px) {
    .features-grid {
      grid-template-columns: repeat(4, 1fr);
    }
    .features {
      padding: 8rem 0;
    }
  }
</style>
