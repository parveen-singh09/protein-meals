---
import { foods } from '../data/foods';
---

<section class="hero">
  <div class="container hero-content">
    <div class="hero-text fade-in">
      <div class="hero-badge glass">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
        Completely Free Resource
      </div>
      <h1 class="hero-title">
        Discover <span class="gradient-text">High Protein</span> Foods
      </h1>
      <p class="hero-subtitle">
        Explore {foods.length}+ protein-rich foods with complete macros, micros, prices, and HD images.
        Data sourced from USDA FoodData Central. Free for everyone.
      </p>
      <div class="hero-actions">
        <a href="#foods" class="btn btn-hero">
          Browse All Foods
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
        </a>
      </div>
    </div>

  </div>
</section>

<section id="features" class="features">
  <div class="container">
    <div class="section-label">Why Choose HighProtein Valley</div>
    <h2 class="features-title">Everything You Need to Track Your Protein</h2>

    <div class="features-grid">
      <div class="feature-card glass fade-in">
        <div class="feature-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M6 13.87A4 4 0 0 1 7.41 6a5.11 5.11 0 0 1 1.05-1.54 5 5 0 0 1 7.08 0A5.11 5.11 0 0 1 16.59 6 4 4 0 0 1 18 13.87V21H6Z"/>
          </svg>
        </div>
        <h3>Complete Macros</h3>
        <p>Protein, calories, carbs, fat, and fiber per 100g for every food item. No guesswork.</p>
      </div>

      <div class="feature-card glass fade-in" style="animation-delay: 80ms">
        <div class="feature-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
          </svg>
        </div>
        <h3>Price Tracking</h3>
        <p>Average prices included so you can find the best protein per dollar value for your budget.</p>
      </div>

      <div class="feature-card glass fade-in" style="animation-delay: 160ms">
        <div class="feature-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/>
          </svg>
        </div>
        <h3>Smart Sorting</h3>
        <p>Sort by protein content, calories, protein per dollar, protein per calorie, and more.</p>
      </div>

      <div class="feature-card glass fade-in" style="animation-delay: 240ms">
        <div class="feature-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
          </svg>
        </div>
        <h3>Micronutrients</h3>
        <p>Detailed vitamin and mineral profiles for each food. Know exactly what you're getting.</p>
      </div>

      <div class="feature-card glass fade-in" style="animation-delay: 320ms">
        <div class="feature-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
          </svg>
        </div>
        <h3>USDA Verified</h3>
        <p>All data sourced from USDA FoodData Central (fdc.nal.usda.gov) — the most reliable nutrition database.</p>
      </div>

      <div class="feature-card glass fade-in" style="animation-delay: 400ms">
        <div class="feature-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/>
          </svg>
        </div>
        <h3>Filter & Search</h3>
        <p>Filter by category, availability, or search by name, description, and tags to find exactly what you need.</p>
      </div>
    </div>
  </div>
</section>




<style>
  .hero {
    position: relative;
    min-height: 85dvh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding-top: 64px;
  }



  .hero-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 3rem;
    padding: 4rem 0;
  }

  .hero-text {
    max-width: 680px;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0.875rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--accent-green);
    margin-bottom: 1.5rem;
  }

  .hero-title {
    font-size: clamp(2.25rem, 6vw, 4rem);
    font-weight: 800;
    line-height: 1.1;
    margin: 0 0 1.25rem;
    letter-spacing: -0.02em;
  }

  .gradient-text {
    background: linear-gradient(135deg, var(--accent-green), var(--accent-teal), var(--accent-lime));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.125rem);
    color: var(--text-secondary);
    line-height: 1.7;
    margin: 0 0 2rem;
    max-width: 560px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
  }

  .btn-hero {
    padding: 0.75rem 1.5rem;
    font-size: 1rem;
  }



  .features {
    padding: 6rem 0;
    scroll-margin-top: 80px;
  }

  .section-label {
    text-align: center;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent-green);
    font-weight: 600;
    margin-bottom: 0.75rem;
  }

  .features-title {
    text-align: center;
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    margin: 0 auto 3rem;
    color: var(--text-primary);
    max-width: 520px;
  }

  .features-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  .feature-card {
    padding: 1.5rem;
    transition: all 0.3s;
  }

  .feature-card:hover {
    transform: translateY(-2px);
    background: var(--surface-hover);
  }

  .feature-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 0.625rem;
    background: rgba(34, 197, 94, 0.1);
    color: var(--accent-green);
    margin-bottom: 1rem;
  }

  .feature-card h3 {
    font-size: 1.0625rem;
    margin: 0 0 0.5rem;
  }

  .feature-card p {
    font-size: 0.875rem;
    color: var(--text-secondary);
    margin: 0;
    line-height: 1.6;
  }

  .categories-section {
    padding: 4rem 0;
    scroll-margin-top: 80px;
  }

  .categories-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 1rem;
  }

  .category-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 1.5rem 1rem;
    text-align: center;
    text-decoration: none;
    transition: all 0.3s;
    gap: 0.375rem;
  }

  .category-card:hover {
    background: var(--surface-hover);
    transform: translateY(-2px);
  }

  .category-emoji {
    font-size: 2rem;
    line-height: 1;
  }

  .category-name {
    font-size: 0.9375rem;
    font-weight: 600;
  }

  .category-count {
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .top-picks {
    padding: 4rem 0 6rem;
    scroll-margin-top: 80px;
  }

  .top-list {
    max-width: 600px;
    margin: 0 auto;
    overflow: hidden;
  }

  .top-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.875rem 1.25rem;
    transition: background 0.2s;
  }

  .top-item:not(:last-child) {
    border-bottom: 1px solid rgba(0, 0, 0, 0.04);
  }

  .top-item:hover {
    background: rgba(0, 0, 0, 0.03);
  }

  :root.dark .top-item:not(:last-child) {
    border-bottom-color: rgba(255, 255, 255, 0.04);
  }

  :root.dark .top-item:hover {
    background: rgba(255, 255, 255, 0.04);
  }

  .top-rank {
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--accent-green);
    font-family: var(--font-mono);
    width: 28px;
    flex-shrink: 0;
  }

  .top-info {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .top-name {
    font-size: 0.875rem;
    font-weight: 600;
  }

  .top-category {
    font-size: 0.7rem;
    color: var(--text-muted);
    text-transform: capitalize;
  }

  .top-value {
    font-size: 1rem;
    font-weight: 700;
    font-family: var(--font-mono);
    color: var(--accent-teal);
    text-align: right;
  }

  .top-value small {
    font-size: 0.65rem;
    font-weight: 400;
    color: var(--text-muted);
  }

  .top-meta {
    font-size: 0.75rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
    min-width: 60px;
    text-align: right;
  }

  @media (min-width: 640px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .features-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
